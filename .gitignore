# ─────────────────────────────────────────────
# SS Doors Manager — .gitignore
# Electron + Vite + React + TypeScript + SQLite
# ─────────────────────────────────────────────

# ── Dependencies ──────────────────────────────
node_modules/

# ── Build outputs ─────────────────────────────
dist/
dist-electron/
dist-ssr/

# ── Electron-builder release artifacts ────────
release/

# ── Logs ──────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── SQLite databases (local runtime data) ─────
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ── Environment & secrets ─────────────────────
.env
.env.*
!.env.example

# ── OS-generated files ────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Editor/IDE directories ────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# ── TypeScript cache ──────────────────────────
*.tsbuildinfo

# ── Vite cache ────────────────────────────────
.vite/

# ── Local test files & temp files ─────────────
*.local
*.tmp
*.temp

# ── Agent/AI tool directories (not for VCS) ───
.agents/
.claude/
.codex/
.cursor/
.gemini/
.impeccable/
